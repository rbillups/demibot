# Copy this file to `.env` and fill in your values.
# Never commit `.env` or real tokens to Git.

# REQUIRED — Secret (rotate immediately if ever exposed)
# Create at: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# REQUIRED — Configuration (not secret, but identify your server channels)
# Enable Developer Mode in Discord, then right-click a channel → Copy Channel ID
VOICE_ALERT_CHANNEL_ID=your_voice_alert_channel_id
MOTIVATION_CHANNEL_ID=your_motivation_channel_id

# OPTIONAL — For local testing or alternate output channel
# TESTING_CHANNEL_ID=your_testing_channel_id
